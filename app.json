{
  "expo": {
    "name": "Shade",
    "slug": "shade",
    "version": "1.0.0",
    "scheme": "shade",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shade.uvindex"
    },
    "android": {
      "package": "com.shade.uvindex",
      "adaptiveIcon": {
        "backgroundColor": "#0B1120",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Shade uses your location to show the live UV index where you are."
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "UvSmall",
              "label": "Shade UV (1×1)",
              "description": "Current UV index at a glance.",
              "minWidth": "40dp",
              "minHeight": "40dp",
              "targetCellWidth": 1,
              "targetCellHeight": 1,
              "previewImage": "./assets/icon.png",
              "updatePeriodMillis": 1800000,
              "resizeMode": "none"
            },
            {
              "name": "UvMedium",
              "label": "Shade UV (2×2)",
              "description": "UV index, risk level, and today's max.",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "previewImage": "./assets/icon.png",
              "updatePeriodMillis": 1800000,
              "resizeMode": "none"
            },
            {
              "name": "UvLarge",
              "label": "Shade UV (4×2)",
              "description": "Location, UV index, protection tip, and today's max.",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "previewImage": "./assets/icon.png",
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            },
            {
              "name": "UvStrip",
              "label": "Shade UV (4×1)",
              "description": "Slim bar: UV index and quick tip.",
              "minWidth": "250dp",
              "minHeight": "40dp",
              "targetCellWidth": 4,
              "targetCellHeight": 1,
              "previewImage": "./assets/icon.png",
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal"
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
